            "id": "a991435c-89ad-4303-b6f0-a18054cc0ea7",
            "command": "EVENT_TEXT",
            "args": {
              "text": [
                "Good, you got the\nsquirrel. If I tell ma I\ndid it, maybe she'll let me\nback in."
              ]
            }
          },
          {
            "id": "be420a1a-743e-4afc-a997-daf721708b34",
